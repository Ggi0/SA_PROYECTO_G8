    <!-- ══════════════════════════════════════
         NOTAS GLOBALES
    ══════════════════════════════════════ -->
    <mxCell id="nota_sp" value="«SP» = Stored Procedure PostgreSQL&#xa;«trigger» = trg_audit_credentials (disparo automático)&#xa;«view» = vw_catalog / vw_actor_detail&#xa;«fn» = fn_recommendation_percentage&#xa;Todos los servicios se comunican vía gRPC síncrono (HTTP/2)&#xa;Protocol Buffers definen los contratos entre servicios" style="text;html=1;strokeColor=#2C3E50;fillColor=#F8F9FA;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontColor=#1A2C4A;" vertex="1" parent="1">
      <mxGeometry x="10" y="2540" width="450" height="100" as="geometry"/>
    </mxCell>

    <mxCell id="nota_colores" value="Convención de colores:&#xa;■ Borde rojo = objetos de BD programables (SP, trigger, view, fn)&#xa;■ Fondo rojo claro = error / flujo de excepción&#xa;■ Fondo verde claro = éxito / resultado positivo&#xa;■ Fondo amarillo = decisiones (rombos) y Redis Cache&#xa;■ Borde dorado = Redis / FX Service / Notificaciones" style="text;html=1;strokeColor=#2C3E50;fillColor=#F8F9FA;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontColor=#1A2C4A;" vertex="1" parent="1">
      <mxGeometry x="480" y="2540" width="480" height="100" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
