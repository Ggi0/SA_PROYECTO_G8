        <mxCell id="hdr_adm_st" parent="1" value="ADMIN - Storage GCS (HTTP proxy :8082)" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#2A7A2A;strokeColor=#1A5A1A;fontColor=#FFFFFF;fontSize=10;fontStyle=1;align=center;" vertex="1">
