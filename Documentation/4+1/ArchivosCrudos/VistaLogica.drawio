        <mxCell id="hdr_adm_au" parent="1" value="ADMIN - Auditoria (HTTP proxy :8082)" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#7B1FA2;strokeColor=#5A0070;fontColor=#FFFFFF;fontSize=10;fontStyle=1;align=center;" vertex="1">
          <mxGeometry x="850" y="814" width="380" height="28" as="geometry" />
