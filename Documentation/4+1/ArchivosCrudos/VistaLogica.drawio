        <mxCell id="ctac" parent="1" value="POST   /api/catalog/admin/content&#xa;       body: { content_type: MOVIE|SERIES, title, synopsis,&#xa;               release_year, duration_min, genre_ids: int[] }&#xa;       resp: { content_id: uuid }&#xa;&#xa;PUT    /api/catalog/admin/content/:id&#xa;       body: { title?, synopsis?, release_year?, duration_min?, genre_ids? }&#xa;       resp: ContentDetail actualizado&#xa;&#xa;POST   /api/catalog/admin/content/:id/publish&#xa;       body: {} - sets is_published=TRUE en BD&#xa;       resp: { success: true, published_at: ISO8601 }&#xa;&#xa;DELETE /api/catalog/admin/content/:id&#xa;       body: { changed_by? } - elimina de BD permanentemente&#xa;       resp: { success: true }&#xa;&#xa;POST   /api/catalog/admin/content/:id/schedule&#xa;       body: { premiere_date: ISO8601, changed_by? }&#xa;       resp: { success: true, premiere_date: ISO8601 }&#xa;&#xa;GET    /api/catalog/admin/content/all?type, genre_id, page&#xa;       [ListAllContent] retorna is_published TRUE y FALSE&#xa;       resp: { items: ContentCard[], total, page }" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#FFF3E0;strokeColor=#E07000;strokeWidth=2;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1">
