        <mxCell id="ctubox" parent="1" value="GET  /api/catalog?type=MOVIE|SERIES, genre_id, page&#xa;     resp: { items: ContentCard[], total, page }&#xa;&#xa;GET  /api/catalog/search?q, type&#xa;     resp: { results: [{ content_id, title, poster_url }] }&#xa;&#xa;GET  /api/catalog/genres&#xa;     resp: { genres: [{ genre_id, name, slug }] }&#xa;&#xa;GET  /api/catalog/content/:id&#xa;     resp: ContentDetail { title, synopsis, cast[], genres[], is_published }&#xa;&#xa;GET  /api/catalog/series/:id/structure&#xa;     resp: { seasons: [{ episodes: [{ episode_id, title }] }] }&#xa;&#xa;GET  /api/catalog/person/:id&#xa;     resp: PersonDetail { full_name, bio, filmography[] }&#xa;&#xa;GET  /api/catalog/content/:id/rating?profile_id&#xa;     resp: { thumb: UP|DOWN, stars: 1-5 }&#xa;&#xa;POST /api/catalog/content/:id/rate&#xa;     body: { profile_id, thumb: UP|DOWN, stars: 1-5 }&#xa;     resp: { success, like_pct, avg_stars }" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#EBF3FF;strokeColor=#1A2C4A;strokeWidth=2;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1">
          <mxGeometry x="20" y="286" width="390" height="472" as="geometry" />
