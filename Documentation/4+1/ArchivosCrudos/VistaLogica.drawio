        <mxCell id="ctaau" parent="1" value="GET /api/catalog/admin/audit/logs&#xa;    ?entity=content|genre|person&#xa;    &amp;action=CREATE|UPDATE|DELETE|PUBLISH&#xa;    &amp;from=ISO8601 &amp;to=ISO8601 &amp;page=int&#xa;    resp: { logs: [{ id, entity, entity_id, action,&#xa;                     changed_by, changed_at,&#xa;                     old_values: JSON, new_values: JSON }],&#xa;            total: int }&#xa;&#xa;GET /api/catalog/admin/audit/export&#xa;    ?format=csv|pdf &amp;entity &amp;action &amp;from &amp;to&#xa;    resp: archivo descargable&#xa;    Content-Disposition: attachment; filename=audit_export.csv" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1">
