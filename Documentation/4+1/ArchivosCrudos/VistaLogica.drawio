        <mxCell id="ctase" parent="1" value="POST   /api/catalog/admin/content/:id/seasons&#xa;       body: { season_num: int, title?: string }&#xa;       resp: { season_id: uuid, season_num, title }&#xa;&#xa;DELETE /api/catalog/admin/seasons/:id&#xa;       body: { changed_by? }  resp: { success: true }&#xa;&#xa;POST   /api/catalog/admin/seasons/:id/episodes&#xa;       body: { episode_num: int, title, synopsis?, duration_min? }&#xa;       resp: { episode_id: uuid, episode_num, title }&#xa;&#xa;PUT    /api/catalog/admin/episodes/:id&#xa;       body: { title?, synopsis?, duration_min?, episode_num? }&#xa;       resp: EpisodeDetail actualizado&#xa;&#xa;DELETE /api/catalog/admin/episodes/:id&#xa;       body: { changed_by? }  resp: { success: true }" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#FFF3E0;strokeColor=#E07000;strokeWidth=2;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1">
