        <mxCell id="ctap" parent="1" value="POST   /api/catalog/admin/people&#xa;       body: { full_name, bio?, birth_date?: ISO8601, nationality? }&#xa;       resp: { person_id: uuid, full_name }&#xa;&#xa;PUT    /api/catalog/admin/people/:id&#xa;       body: { full_name?, bio?, birth_date?, nationality? }&#xa;       resp: PersonDetail actualizado&#xa;&#xa;DELETE /api/catalog/admin/people/:id&#xa;       body: { changed_by? }  resp: { success: true }&#xa;&#xa;POST   /api/catalog/admin/content/:id/cast&#xa;       body: { person_id: uuid, role_type: ACTOR|DIRECTOR|PRODUCER|WRITER,&#xa;               character_name?, order?: int }&#xa;       resp: { success: true }&#xa;&#xa;DELETE /api/catalog/admin/content/:cId/cast/:pId?role_type=ACTOR&#xa;       resp: { success: true }" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#FFF3E0;strokeColor=#E07000;strokeWidth=2;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1">
          <mxGeometry x="850" y="514" width="380" height="280" as="geometry" />
