          <mxGeometry height="16" width="770" x="20" y="554" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-46" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#1A2C4A;" value="  Cache-Aside Redis (patrón obligatorio — enunciado):" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="574" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-47" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="  ├─ FX Service → busca clave fx:USD:GTQ en Redis Memorystore" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="590" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-48" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="  ├─ Cache HIT → devuelve tipo de cambio ~1ms (TTL 3600s aún vigente)" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="606" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-49" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="  └─ Cache MISS → llama ExchangeRate API externa (HTTPS) → guarda en Redis con TTL=3600s" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="622" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-50" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="• Subscription Service → precio_GTQ = precio_USD × tipo_cambio → devuelve planes en GTQ" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="642" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-51" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="• Usuario selecciona plan → POST /subscribe → API Gateway → gRPC Subscribe()" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="658" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-52" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="• Subscription Service → sp_process_subscription() [stored procedure PostgreSQL]" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="674" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-53" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="  Transacción atómica: registra pago + activa plan · COMMIT si todo OK / ROLLBACK si falla" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="690" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-54" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="• Subscription Service → gRPC SendReceiptEmail() [notification.proto] → Notification Service" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="706" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-55" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#333333;" value="• Notification Service → envía recibo.html vía aiosmtplib → SMTP Gmail :587" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="722" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-56" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#555555;" value="Flujo error — pago rechazado: sp_process_subscription() ROLLBACK → { error: Pago rechazado } → 402 · Notification Service → email de pago fallido" vertex="1">
          <mxGeometry height="16" width="770" x="20" y="746" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-57" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontColor=#555555;" value="Mecanismo clave: Redis Memorystore (GCP) con TTL 3600s evita saturar la API externa de divisas con cada request de precios." vertex="1">
          <mxGeometry height="16" width="770" x="20" y="778" as="geometry" />
        </mxCell>
