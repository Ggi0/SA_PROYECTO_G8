          <mxGeometry height="16" width="770" x="20" y="794" as="geometry" />
        </mxCell>
        <mxCell id="Onu891SawI3-nKJyKs4R-59" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C3E50;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="370" width="824" x="820" y="460" as="geometry" />
