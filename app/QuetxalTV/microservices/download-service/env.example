# ─────────────────────────────────────────────
# download-service — Variables de entorno
# Copiar como .env y completar valores reales.
# NUNCA subir .env al repositorio.
# ─────────────────────────────────────────────

# gRPC
GRPC_PORT=50055

# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=downloads_db
DB_USER=downloads_user
DB_PASSWORD=
DB_SSLMODE=disable

# JWT (debe coincidir con el api-gateway)
JWT_SECRET=

# Google Cloud Storage
GCS_BUCKET=quetxaltv-downloads

# Configuración de descargas
DOWNLOAD_EXPIRY_DAYS=30
