  "item": [
    {
      "name": "01 - Listar planes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/subscriptions/plans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "subscriptions",
            "plans"
          ]
        },
        "description": "Endpoint publico. Devuelve los planes disponibles. Usa el id 1, 2 o 3 para las pruebas siguientes."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Tiene planes', () => pm.expect(json.plans.length).to.be.above(0));",
              "if (json.plans && json.plans.length) pm.collectionVariables.set('planId', json.plans[0].id);"
            ]
          }
        }
      ]
    },
    {
