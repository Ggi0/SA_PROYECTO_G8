# ─────────────────────────────────────────────
#  API Gateway — variables de entorno
# ─────────────────────────────────────────────

PORT=3000

# ── JWT existente (usado por jwt.guard.ts / SubscriptionModule) ──
JWT_SECRET=local_dev_secret

# ── JWT del Auth Service (usado por auth-jwt.guard.ts) ──────────
# Debe coincidir exactamente con JWT_ACCESS_SECRET del auth-service
JWT_ACCESS_SECRET=super_access_secret_cambiala

# ── Microservicios ───────────────────────────────────────────────
SUBSCRIPTION_SERVICE_URL=subscription-service:50053
# AUTH_SERVICE_URL=auth-service:50051

# En desarrollo local (sin Docker):
AUTH_SERVICE_URL=localhost:50051
FX_SERVICE_URL=localhost:50054
